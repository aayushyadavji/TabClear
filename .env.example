# Tabclear — Stellar Testnet contract IDs.
# Run scripts/deploy.sh to deploy both contracts, then paste the printed IDs here.

# Orange Belt: tabclear-requests (payment request ledger).
VITE_REQUESTS_ID=

# Orange Belt: tabclear-settlement (atomic one-tx pay via cross-contract calls).
VITE_SETTLEMENT_ID=

# Back-compat (Yellow Belt): older builds read VITE_CONTRACT_ID for the requests
# contract. VITE_REQUESTS_ID takes precedence if both are set.
# VITE_CONTRACT_ID=
